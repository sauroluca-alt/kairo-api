{
  "name": "kairo-api",
  "version": "1.0.0",
  "description": "Kairo API REST — Node.js + TypeScript + Fastify",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "node -r tsx/cjs src/db/migrate.ts",
    "db:seed": "node -r tsx/cjs src/db/seed.ts",
    "lint": "eslint src --ext .ts",
    "test": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "axios": "^1.7.2",
    "bcryptjs": "^3.0.3",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.1",
    "postgres": "^3.4.4",
    "redis": "^4.7.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "google-auth-library": "^9.14.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.7.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.4"
  }
}
